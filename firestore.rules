rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function myRole() {
      return isSignedIn() ? userDoc(request.auth.uid).data.role : "";
    }

    function isAdmin() {
      return isSignedIn() && myRole() == "admin";
    }

    function myCommunityId() {
      return isSignedIn() ? userDoc(request.auth.uid).data.communityId : "";
    }

    // ─────────────────────────────────────────────
    // Users
    // ─────────────────────────────────────────────
    match /users/{userId} {
      // Self read/write
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Admin can read resident profiles within their community
      allow read: if isAdmin()
        && resource.data.role == "resident"
        && resource.data.communityId == myCommunityId();

      // Admin can update ONLY resident communityId during approval (prevents admin editing everything)
      allow update: if isAdmin()
        && resource.data.role == "resident"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["communityId"])
        && request.resource.data.communityId == myCommunityId();
    }

    // ─────────────────────────────────────────────
    // Communities
    // ─────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // Join Requests
    // ─────────────────────────────────────────────
    match /joinRequests/{requestId} {

      allow create: if isSignedIn()
        && request.resource.data.residentUid == request.auth.uid
        && request.resource.data.communityId is string
        && request.resource.data.communityId != "";

      allow read: if isSignedIn() && (
        resource.data.residentUid == request.auth.uid
        || (isAdmin() && resource.data.communityId == myCommunityId())
      );

      allow update, delete: if isAdmin() && resource.data.communityId == myCommunityId();
    }

    // ─────────────────────────────────────────────
    // Complaints
    // ─────────────────────────────────────────────
    match /complaints/{complaintId} {

      // Resident create: must be for themselves AND must include a communityId.
      // (If you allow blank communityId, admin-community queries and rules break.)
      allow create: if isSignedIn()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.communityId is string
        && request.resource.data.communityId != "";

      allow read: if isSignedIn() && (
        resource.data.reportedBy == request.auth.uid
        || (isAdmin() && resource.data.communityId == myCommunityId())
      );

      allow update: if isSignedIn() && (
        (isAdmin() && resource.data.communityId == myCommunityId())
        || (
          resource.data.reportedBy == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys()
              .hasOnly([
                "status",
                "resolvedConfirmedByResident",
                "assignedProvider",
                "updatedAt"
              ])
        )
      );

      allow delete: if isAdmin() && resource.data.communityId == myCommunityId();
    }

    // ─────────────────────────────────────────────
    // Service Providers
    // ─────────────────────────────────────────────
    match /serviceProviders/{providerId} {
      allow read: if isSignedIn() && resource.data.communityId == myCommunityId();

      allow create, update, delete: if isAdmin()
        && request.resource.data.communityId == myCommunityId();
    }

    // ─────────────────────────────────────────────
    // FCM Tokens (push notification targeting)
    // ─────────────────────────────────────────────
    match /fcmTokens/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn() && request.auth.uid == uid;

      match /tokens/{tokenId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ─────────────────────────────────────────────
    // Notifications
    // ─────────────────────────────────────────────
    match /notifications/{notificationId} {

      // Read:
      // - Owner can read
      // - Admin can read notifications for their own community (admin dashboard view)
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId
        || (
          isAdmin()
          && resource.data.communityId is string
          && resource.data.communityId == myCommunityId()
        )
      );

      // Update/Delete: only owner (mark read)
      allow update, delete: if isSignedIn()
        && request.auth.uid == resource.data.userId;

      // Create:
      // - user can create for themselves
      // - admin can create for their community
      // - resident can create notifications targeted to the community admin
      //   (needed for admin Notifications tab when resident creates/reopens/updates complaints)
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
        || (
          isAdmin()
          && request.resource.data.communityId is string
          && request.resource.data.communityId == myCommunityId()
        )
        || (
          // resident -> admin
          request.resource.data.communityId is string
          && request.resource.data.communityId == myCommunityId()
          && request.resource.data.userId is string
          && request.resource.data.userId == get(/databases/$(database)/documents/communities/$(myCommunityId())).data.adminUid
        )
      );
    }
  }
}
