<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Header ── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_header_gradient"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back_black_24"
            android:contentDescription="@string/go_back"
            android:padding="6dp"
            app:tint="@color/white"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Report Issue"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- ── Step Indicator ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStep1"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_circle_blue" />

        <View
            android:id="@+id/line1"
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="@color/divider"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tvStep2"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_circle_green" />

        <View
            android:id="@+id/line2"
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="@color/divider"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tvStep3"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_circle_green" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStepLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Step 1: Select Category"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <!-- ── Content ViewFlipper (3 steps) ── -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ════ STEP 1: Category Selection ════ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/llCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <EditText
                    android:id="@+id/etCustomCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_white"
                    android:padding="14dp"
                    android:hint="Specify the issue type (e.g. Pest Control, Painting)"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:visibility="gone"
                    android:layout_marginTop="12dp" />

            </LinearLayout>
        </ScrollView>

        <!-- ════ STEP 2: Details (Photo + Location + Description) ════ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Photo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Photo"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:id="@+id/framePhoto"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ivPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="Complaint photo" />

                    <LinearLayout
                        android:id="@+id/llAddPhoto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:contentDescription="Add photo"
                            android:layout_gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to add photo"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Location -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <!-- Auto Location (GPS) + Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <EditText
                        android:id="@+id/etAutoLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_white"
                        android:padding="14dp"
                        android:hint="Tap 'Use Current Location'"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:enabled="false"
                        android:focusable="false"
                        android:maxLines="2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUseLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Use Current"
                        android:textAllCaps="false"
                        style="@style/Widget.Material3.Button" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvLocationNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GPS gives an approximate area. Please add the exact spot below."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp" />

                <!-- Landmark / Exact Place (Manual Input) -->
                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_white"
                    android:padding="14dp"
                    android:hint="Landmark / Exact place (e.g. Behind Block B, near garden tap)"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:maxLines="2"
                    android:layout_marginBottom="16dp" />

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_input_white"
                    android:padding="12dp"
                    android:hint="Describe the issue in detail..."
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:layout_marginBottom="16dp" />

                <!-- Priority -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Priority"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rgPriority"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/rbNormal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Normal"
                        android:textColor="@color/text_primary"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rbUrgent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Urgent"
                        android:textColor="@color/text_primary" />
                </RadioGroup>

            </LinearLayout>
        </ScrollView>

        <!-- ════ STEP 3: Review & Submit ════ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Review Your Complaint"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <ImageView
                    android:id="@+id/ivReviewPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="12dp"
                    android:contentDescription="Complaint photo preview" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvReviewCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvReviewDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvReviewLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Priority"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvReviewPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <CheckBox
                    android:id="@+id/cbConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="I confirm the details are accurate"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

            </LinearLayout>
        </ScrollView>

    </ViewFlipper>

    <!-- ── Bottom Buttons ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnPrevious"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Previous"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Next"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- ── Loading ── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>

