<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_header_gradient"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back_black_24"
            android:contentDescription="Back"
            android:padding="6dp"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Complaint Details"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Image -->
            <ImageView
                android:id="@+id/ivComplaintImage"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_input_white"
                android:layout_marginBottom="16dp"
                android:contentDescription="Complaint image" />

            <!-- Status + Category Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="4dp" />

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="4dp" />

            <!-- ✅ Open in Maps (only shown when GPS coordinates exist) -->
            <Button
                android:id="@+id/btnOpenInMaps"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:text="Open in Maps"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Reported By -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reported By"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvReportedBy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="4dp" />

            <!-- Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reported On"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="4dp" />

            <!-- Status Timeline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status Timeline"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/llTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp" />

            <!-- ═══ Assigned Provider Info (visible to BOTH admin & resident) ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProviderInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#F0F7FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assigned Service Provider"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Provider Icon -->
                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_category_icon_circle">

                            <TextView
                                android:id="@+id/tvProviderInfoIcon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textSize="20sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvProviderInfoName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvProviderInfoCategory"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:id="@+id/tvProviderInfoPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ── Call Provider Button (visible to BOTH admin & resident) ── -->
                    <Button
                        android:id="@+id/btnCallProvider"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_btn_call"
                        android:drawableStart="@drawable/ic_call"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:text="Call Provider"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Admin Actions (visible only for admin) -->
            <LinearLayout
                android:id="@+id/llAdminActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Actions"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <!-- Assigned Provider Display (admin only — with Change/Remove) -->
                <LinearLayout
                    android:id="@+id/llAssignedProvider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:background="@drawable/bg_input_white"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Provider"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/btnRemoveProvider"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Remove"
                            android:textColor="@color/error"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:padding="4dp"
                            android:background="?selectableItemBackground" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAssignedProviderName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Assign / Change Provider Section -->
                <LinearLayout
                    android:id="@+id/llAssignSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAssignLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assign Service Provider"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerProvider"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_white"
                        android:paddingHorizontal="10dp"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnAssignProvider"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Assign Provider"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/secondary"
                        android:layout_marginBottom="12dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnMarkInProgress"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Mark In Progress"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_btn_primary"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnMarkResolved"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Mark Resolved"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/success"
                    android:layout_marginBottom="8dp" />
            </LinearLayout>

            <!-- Resident Confirmation (visible when resolved) -->
            <LinearLayout
                android:id="@+id/llResidentConfirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Is this issue resolved?"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnConfirmYes"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="👍 Yes, Fixed"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/success"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnConfirmNo"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="👎 No, Reopen"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/error"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>

