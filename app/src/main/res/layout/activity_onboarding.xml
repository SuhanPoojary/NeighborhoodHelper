<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_onboarding.xml — Container for 3 swipeable onboarding pages.
    Uses ViewPager2 for smooth swiping + dot indicators.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ViewPager2 takes up most of the screen -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom section: dots + buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Dot indicators (3 dots) -->
        <LinearLayout
            android:id="@+id/dotsLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp" />

        <!-- Buttons row: Skip (left) and Next/Get Started (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Skip button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkip"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/btn_skip"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Next / Get Started button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/btn_next"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                app:cornerRadius="24dp"
                android:paddingStart="32dp"
                android:paddingEnd="32dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

